# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
APP_DEBUG=true
APP_TITLE=Order Management System
APP_VERSION=1.0.0

# Database
DATABASE_URL=sqlite:///./oms.db

# JWT
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=human

# Bug Injection (all disabled by default)
ENABLE_NEGATIVE_INVENTORY=false
ENABLE_DUPLICATE_PAYMENT=false
ENABLE_WRONG_GST=false
ENABLE_SKIP_AUDIT_LOG=false
ENABLE_SHIPMENT_WITHOUT_PAYMENT=false
